# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
  colors = true
  interval = 5
  output_format = i3bar
}

order += "read_file POMODERO"
order += "ethernet _first_"
order += "path_exists NORDVPN"
order += "disk /"
order += "disk /home"
order += "tztime holder__dunst_pause_level"
order += "volume master"
order += "load"
order += "memory"
order += "tztime local"

tztime holder__dunst_pause_level {
  format = "holder__dunst_pause_level"
}

read_file POMODERO {
  format = "%content"
  format_bad = "No Pomodero Timer"
  path = "/home/tyler/.config/i3status/pomodero"
}

volume master {
  format = "🔊 %volume"
  format_muted = "🔇 %volume"
  device = "default"
  mixer = "Master"
  mixer_idx = 0
}

ethernet _first_ {
  format_up = "%ip (%speed)"
  format_down = "ETHERNET DOWN"
}

path_exists NORDVPN {
  # Might not be NORDVPN specific, but this is what nordvpn
  # makes now.
  path = "/proc/sys/net/ipv4/conf/tun0"
}


disk "/" {
  format = "💽 %used/%total"
}

disk "/home" {
  format = "🏠 %used/%total"
}

load {
  format = "💭 %1min"
}

memory {
  format = " %used/%total"
  threshold_degraded = "1G"
  format_degraded = "MEMORY < %available"
}

tztime local {
  format = "%Y-%m-%d %H:%M:%S"
}
